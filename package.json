{
  "name": "postorama",
  "version": "0.1.0",
  "description": "macOS menubar app for sending postcards via Lob",
  "main": "dist/main/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "yarn dev:setup && concurrently -n main,renderer,css,electron \"yarn dev:main\" \"yarn dev:renderer\" \"yarn dev:css\" \"yarn dev:electron\"",
    "dev:setup": "mkdir -p dist/renderer && cp src/renderer/index.html dist/renderer/index.html",
    "dev:main": "tsc -p tsconfig.main.json --watch --outDir dist",
    "dev:renderer": "esbuild src/renderer/index.tsx --bundle --outfile=dist/renderer/bundle.js --sourcemap --watch --loader:.tsx=tsx --loader:.ts=ts --jsx=automatic --platform=browser --target=chrome120",
    "dev:css": "tailwindcss -i src/renderer/styles/globals.css -o dist/renderer/styles.css --watch",
    "dev:electron": "wait-on dist/main/index.js dist/renderer/bundle.js dist/renderer/styles.css && electron .",
    "build:swift": "swiftc -o scripts/contact-lookup scripts/contact-lookup.swift",
    "build": "yarn build:swift && yarn build:main && yarn build:renderer && yarn build:css",
    "build:main": "tsc -p tsconfig.main.json --outDir dist",
    "build:renderer": "esbuild src/renderer/index.tsx --bundle --outfile=dist/renderer/bundle.js --loader:.tsx=tsx --loader:.ts=ts --jsx=automatic --platform=browser --target=chrome120 --minify",
    "build:css": "tailwindcss -i src/renderer/styles/globals.css -o dist/renderer/styles.css --minify",
    "rebuild": "electron-rebuild -f -w better-sqlite3,sharp",
    "package": "yarn build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html}\""
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.64.0",
    "better-sqlite3": "^12.6.2",
    "date-fns": "^4.1.0",
    "electron-store": "^8.2.0",
    "menubar": "^9.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "38.0.0-beta.6",
    "electron-builder": "^24.13.3",
    "esbuild": "0.25.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}
